  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum AchievementTier {
  BRONZE
  SILVER
  GOLD
  SAINT
}

enum PartnershipStatus {
  PENDING
  ACTIVE
  DECLINED
  ENDED
}

enum ReminderType {
  MORNING_PRAYER
  ANGELUS
  EVENING_PRAYER
  ROSARY
  EXAMEN
  CONFESSION
  CUSTOM
}

enum CandleDuration {
  ONE_DAY
  THREE_DAYS
  SEVEN_DAYS
  FOURTEEN_DAYS
  THIRTY_DAYS
}

enum PaymentSource {
  CASHFREE_WEB
  CASHFREE_MOBILE
  GOOGLE_PLAY
  APPLE_APPSTORE
  STRIPE
}

// =========================================
// PURCHASE EVENTS (Google Play, App Store)
// =========================================

model PurchaseEvent {
  id                    String        @id @default(cuid())
  userId                String
  
  // Product Info
  source                PaymentSource
  productId             String        // e.g., "plus_monthly", "premium_yearly"
  productType           String        @default("subscription") // subscription, one_time
  
  // Platform-Specific Tokens
  purchaseToken         String?       // Google Play purchase token
  transactionId         String?       // Platform transaction ID
  orderId               String?       // Order ID from platform
  originalTransactionId String?       // For subscription renewals
  
  // Status & Amounts
  status                String        @default("PENDING") // PENDING, COMPLETED, REFUNDED, CANCELLED
  amount                Int?          // Amount in cents
  currency              String?       @default("USD")
  
  // Timing
  purchasedAt           DateTime      @default(now())
  expiresAt             DateTime?     // For subscriptions
  acknowledgedAt        DateTime?     // When purchase was acknowledged
  cancelledAt           DateTime?     // If cancelled
  
  // Raw Data
  rawPayload            Json?         // Full response from platform
  
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  
  User                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([source])
  @@index([purchaseToken])
  @@index([productId])
  @@index([status])
}

// =========================================
// MEMORIAL FEATURE
// =========================================

enum MemorialTier {
  BASIC
  PREMIUM
}

enum MemorialOfferingType {
  CANDLE_SMALL
  CANDLE_MEDIUM
  CANDLE_LARGE
  FLOWERS
  PRAYER_CARD
  FLORAL_BOUQUET
  ROSARY_DECADE
  ROSARY_FULL
  MASS
  SPIRITUAL_BOUQUET_GARDEN
  SPIRITUAL_BOUQUET_HEAVENLY
  SPIRITUAL_BOUQUET_ETERNAL
  SPIRITUAL_BOUQUET_LEGACY
}

model Memorial {
  id              String       @id @default(cuid())
  slug            String       @unique
  
  // Deceased Info
  firstName       String
  lastName        String
  birthDate       DateTime?
  deathDate       DateTime?
  biography       String?      @db.Text
  shortBio        String?      @db.VarChar(500)
  
  // Media
  photoUrl        String?
  videoUrl        String?
  musicUrl        String?
  
  // Settings
  tier            MemorialTier @default(BASIC)
  isPublic        Boolean      @default(true)
  isVerified      Boolean      @default(false)
  
  // Stats
  totalCandles    Int          @default(0)
  totalMasses     Int          @default(0)
  totalFlowers    Int          @default(0)
  totalPrayers    Int          @default(0)
  viewCount       Int          @default(0)
  
  // Payment
  paymentId       String?
  paidAt          DateTime?
  
  // Owner
  ownerId         String
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  owner           User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  offerings       MemorialOffering[]
  guestbook       MemorialGuestbook[]
  photos          MemorialPhoto[]
  
  @@index([ownerId])
  @@index([slug])
  @@index([isPublic])
  @@index([createdAt])
}

model MemorialOffering {
  id            String               @id @default(cuid())
  memorialId    String
  
  // Offerer Info (can be guest or user)
  userId        String?
  guestName     String?
  guestEmail    String?
  
  // Offering Details
  type          MemorialOfferingType
  amount        Int                   // Amount in cents
  message       String?               @db.VarChar(500)
  isAnonymous   Boolean               @default(false)
  
  // Payment
  transactionId String?
  paymentSource String?               // stripe, cashfree, google_play
  
  createdAt     DateTime              @default(now())
  
  memorial      Memorial              @relation(fields: [memorialId], references: [id], onDelete: Cascade)
  user          User?                 @relation(fields: [userId], references: [id])
  
  @@index([memorialId])
  @@index([userId])
  @@index([createdAt])
  @@index([type])
}

model MemorialGuestbook {
  id          String   @id @default(cuid())
  memorialId  String
  
  // Author Info
  userId      String?
  guestName   String?
  
  // Content
  message     String   @db.Text
  
  // Moderation
  isApproved  Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  
  memorial    Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])
  
  @@index([memorialId])
  @@index([createdAt])
}

model MemorialPhoto {
  id          String   @id @default(cuid())
  memorialId  String
  
  url         String
  caption     String?  @db.VarChar(200)
  sortOrder   Int      @default(0)
  
  uploadedBy  String?
  
  createdAt   DateTime @default(now())
  
  memorial    Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)
  
  @@index([memorialId])
  @@index([sortOrder])
}

model AbandonedCart {
  id            String    @id @default(cuid())
  type          String    // MEMORIAL, CANDLE, MASS, OFFERING
  email         String
  name          String?
  phone         String?
  data          Json      // Serialized form data
  step          String    // Last reached step
  source        String?   // "FLUTTER" or "WEB"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Reminder tracking
  reminderCount Int       @default(0)
  lastReminder  DateTime?
  converted     Boolean   @default(false)
  convertedAt   DateTime?

  @@index([email])
  @@index([createdAt])
  @@index([converted])
}

// =========================================
// MODERATION SYSTEM
// =========================================

model Report {
  id          String       @id @default(cuid())
  reason      ReportReason
  description String?      @db.Text
  status      ReportStatus @default(PENDING)
  
  reporterId  String?
  reporter    User?        @relation(fields: [reporterId], references: [id])
  
  targetType  String       // PRAYER_REQUEST, USER, COMMENT
  targetId    String

  details     String?      // Additional JSON details if needed

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([targetType, targetId])
  @@index([reporterId])
}

// =========================================
// CONTACT & SUPPORT
// =========================================

model ContactSubmission {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  subject   String?
  message   String   @db.Text
  status    String   @default("PENDING") // PENDING, REPLIED, ARCHIVED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([email])
  @@index([status])
}

model Testimony {
  id              String           @id @default(cuid())
  userId          String
  title           String
  content         String           @db.Text
  relatedPrayerId String?
  isAnonymous     Boolean          @default(false)
  status          ModerationStatus @default(PENDING)
  isFeatured      Boolean          @default(false)
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  TestimonyUpvote TestimonyUpvote[]
  
  @@index([userId])
  @@index([status])
  @@index([isFeatured])
}

model TestimonyUpvote {
  id          String    @id @default(cuid())
  testimonyId String
  userId      String
  createdAt   DateTime  @default(now())
  
  testimony   Testimony @relation(fields: [testimonyId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([testimonyId, userId])
}

// =========================================
// PRAYER GROUPS
// =========================================

model PrayerGroup {
  id          String   @id @default(cuid())
  name        String
  description String?
  isPrivate   Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  members     PrayerGroupMember[]
  prayers     GroupPrayer[]
  invites     PrayerGroupInvite[]
}

model PrayerGroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  role      String   @default("MEMBER")
  joinedAt  DateTime @default(now())
  
  group     PrayerGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([userId])
}

model PrayerGroupInvite {
  id        String   @id @default(cuid())
  groupId   String
  inviterId String
  inviteeId String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  group     PrayerGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  inviter   User        @relation("SentInvites", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee   User        @relation("ReceivedInvites", fields: [inviteeId], references: [id], onDelete: Cascade)
}

model GroupPrayer {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  
  group     PrayerGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([groupId])
  @@index([userId])
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Donation {
  id              String   @id @default(cuid())
  churchId        String
  userId          String?
  amount          Int
  currency        String   @default("usd")
  message         String?  @db.Text
  isAnonymous     Boolean  @default(false)
  stripeSessionId String?  @unique
  status          String   @default("PENDING") // PENDING, COMPLETED, FAILED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  church          Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  user            User?    @relation(fields: [userId], references: [id])

  @@index([churchId])
  @@index([userId])
  @@index([status])
}

model DailyDevotional {
  id                 String   @id @default(cuid())
  title              String
  scripture          String   @db.Text
  scriptureReference String
  reflection         String   @db.Text
  closingPrayer      String   @db.Text
  publishDate        DateTime @unique
  audioUrl           String?
  isPublished        Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([publishDate])
}

model SystemSetting {
  key         String   @id
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
}

model PrayerPartner {
  id          String            @id @default(cuid())
  requesterId String
  receiverId  String
  status      PrayerPartnerStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  requester   User              @relation("SentPartnerRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver    User              @relation("ReceivedPartnerRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
  @@index([requesterId])
  @@index([receiverId])
  @@index([status])
}

enum PrayerPartnerStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}


model Pilgrimage {
  id            String   @id @default(cuid())
  name          String
  location      String
  country       String
  description   String   @db.Text
  significance  String   @db.Text
  imageUrl      String
  virtualTourUrl String?
  
  viewCount     Int      @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Notification {
  id             String               @id @default(cuid())
  title          String
  message        String               @db.Text
  type           NotificationType
  targetAudience NotificationAudience
  status         NotificationStatus   @default(DRAFT)
  scheduledFor   DateTime?
  sentAt         DateTime?
  metadata       Json? // For deep links or extra data

  // For targeted notifications
  receivers NotificationReceiver[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  createdBy   String?
  createdByUser AdminUser? @relation(fields: [createdBy], references: [id])
}

model NotificationReceiver {
  id             String       @id @default(cuid())
  notificationId String
  userId         String
  readAt         DateTime?
  status         DeliveryStatus @default(PENDING)
  
  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([notificationId, userId])
  @@index([userId])
  @@index([status])
}

enum NotificationType {
  PUSH
  EMAIL
  IN_APP
  ALL
}

enum NotificationAudience {
  ALL
  PREMIUM
  FREE
  SPECIFIC
}

enum NotificationStatus {
  DRAFT
  SCHEDULED
  SENT
  CANCELLED
  FAILED
}

enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   // 'android', 'ios', 'web'
  userAgent String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platform])
}



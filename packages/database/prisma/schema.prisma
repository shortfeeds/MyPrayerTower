model PrayerChallenge {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  description      String
  shortDescription String?
  imageUrl         String?
  type             ChallengeType
  duration         Int           // Days
  startDate        DateTime?
  endDate          DateTime?
  isActive         Boolean       @default(true)
  isPremium        Boolean       @default(false)
  dailyAction      String        // e.g., "Pray the Rosary"
  reward           String?       // Badge or benefit
  participantCount Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  

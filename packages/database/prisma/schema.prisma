generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdminUser {
  id           String    @id
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  createdNotifications Notification[]

  @@index([email])
}

model AppSettings {
  id                  String   @id @default("app_settings")
  siteName            String   @default("MyPrayerTower")
  siteTagline         String   @default("All-in-One Catholic Services")
  
  // System Settings
  maintenanceMode     Boolean  @default(false)
  registrationEnabled Boolean  @default(true)
  prayerWallEnabled   Boolean  @default(true)
  syncEnabled         Boolean  @default(true)
  syncSchedule        String   @default("0 2 * * 0")
  
  // Subscription Pricing (in cents)
  plusMonthlyPrice    Int      @default(499)
  plusYearlyPrice     Int      @default(3999)
  premiumMonthlyPrice Int      @default(999)
  premiumYearlyPrice  Int      @default(7999)
  lifetimePrice       Int      @default(14999)
  
  // Candle Pricing (in cents)
  candleOneDayPrice       Int  @default(0)      // Free
  candleThreeDayPrice     Int  @default(299)    // $2.99
  candleSevenDayPrice     Int  @default(599)    // $5.99
  candleThirtyDayPrice    Int  @default(1499)   // $14.99 Featured
  
  // Mass Offering Pricing (in cents)
  massRegularPrice        Int  @default(1000)   // $10.00
  massExpeditedPrice      Int  @default(2500)   // $25.00
  massNovenaPrice         Int  @default(7500)   // $75.00
  massGregorianPrice      Int  @default(20000)  // $200.00
  massPerpetualPrice      Int  @default(10000)  // $100.00
  
  // Spiritual Bouquet Pricing (in cents)
  bouquetBasePrice        Int  @default(1000)   // $10.00
  bouquetMassAddOn        Int  @default(500)    // $5.00 per Mass
  bouquetCandleAddOn      Int  @default(200)    // $2.00 per Candle
  
  // Feature Toggles
  candlesEnabled            Boolean @default(true)
  massOfferingsEnabled      Boolean @default(true)
  donationsEnabled          Boolean @default(true)
  spiritualBouquetsEnabled  Boolean @default(true)
  challengesEnabled         Boolean @default(true)
  leaderboardEnabled        Boolean @default(true)
  nativeAdsEnabled          Boolean @default(true)
  rewardedAdsEnabled        Boolean @default(true)
  
  // AdMob Configuration
  bannerAdUnitIdAndroid       String?
  bannerAdUnitIdiOS           String?
  interstitialAdUnitIdAndroid String?
  interstitialAdUnitIdiOS     String?
  nativeAdUnitIdAndroid       String?
  nativeAdUnitIdiOS           String?
  rewardedAdUnitIdAndroid     String?
  rewardedAdUnitIdiOS         String?
  
  // Additional Feature Toggles
  rosaryEnabled             Boolean @default(true)
  bibleEnabled              Boolean @default(true)
  dailyReadingsEnabled      Boolean @default(true)
  confessionGuideEnabled    Boolean @default(true)
  examenEnabled             Boolean @default(true)
  stationsOfCrossEnabled    Boolean @default(true)
  novenasEnabled            Boolean @default(true)
  catechismEnabled          Boolean @default(true)
  libraryEnabled            Boolean @default(true)
  liturgicalCalendarEnabled Boolean @default(true)
  quizEnabled               Boolean @default(true)
  saintOfTheDayEnabled      Boolean @default(true)
  memorialsEnabled          Boolean @default(true)
  
  // Memorial Tier Pricing (in cents)
  memorialBasicPrice        Int  @default(2000)    // $20.00
  memorialPremiumPrice      Int  @default(4900)    // $49.00
  
  // Memorial Offering Prices (in cents)
  memorialCandleSmallPrice  Int  @default(100)     // $1.00
  memorialCandleMediumPrice Int  @default(300)     // $3.00
  memorialCandleLargePrice  Int  @default(500)     // $5.00
  memorialFlowersPrice      Int  @default(300)     // $3.00
  memorialPrayerCardPrice   Int  @default(200)     // $2.00
  memorialFloralBouquetPrice Int @default(700)     // $7.00
  memorialRosaryDecadePrice Int  @default(500)     // $5.00
  memorialRosaryFullPrice   Int  @default(1500)    // $15.00
  
  // Memorial Spiritual Bouquet Bundle Prices (in cents)
  memorialBouquetGardenPrice   Int @default(1900)  // $19.00 - Garden of Grace
  memorialBouquetHeavenlyPrice Int @default(4900)  // $49.00 - Heavenly Tribute
  memorialBouquetEternalPrice  Int @default(9900)  // $99.00 - Eternal Peace
  memorialBouquetLegacyPrice   Int @default(29900) // $299.00 - Legacy Remembrance
  
  updatedAt           DateTime @updatedAt
}

model BibleProgress {
  id          String   @id
  userId      String
  book        String
  chapter     Int
  version     String   @default("en-kjv")
  completedAt DateTime @default(now())
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, book, chapter, version])
  @@index([userId])
}

model CanonLaw {
  id              String            @id
  number          Int               @unique
  text            String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  CanonLawSection CanonLawSection[]

  @@index([number])
}

model CanonLawSection {
  id            String   @id
  canonLawId    String
  sectionNumber Int?
  text          String
  CanonLaw      CanonLaw @relation(fields: [canonLawId], references: [id], onDelete: Cascade)

  @@index([canonLawId])
}

model Cardinal {
  id                    String   @id
  rank                  Int      @unique
  name                  String
  country               String
  born                  String?
  order                 String?
  consistory            String?
  office                String?
  papalConclaveEligible Boolean  @default(false)
  createdCardinalBy     String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime

  @@index([country])
  @@index([papalConclaveEligible])
}

model CatechismParagraph {
  id               String            @id
  number           Int               @unique
  content          String
  inBrief          Boolean           @default(false)
  references       String[]
  crossReferences  Int[]
  sectionId        String?
  CatechismSection CatechismSection? @relation(fields: [sectionId], references: [id])

  @@index([inBrief])
  @@index([number])
  @@index([sectionId])
}

model CatechismSection {
  id                 String               @id
  partNumber         Int
  sectionNumber      Int?
  chapterNumber      Int?
  articleNumber      Int?
  title              String
  subtitle           String?
  sortOrder          Int                  @default(0)
  CatechismParagraph CatechismParagraph[]

  @@unique([partNumber, sectionNumber, chapterNumber, articleNumber])
  @@index([partNumber])
  @@index([sortOrder])
}

model Church {
  id                 String               @id
  name               String
  slug               String               @unique
  type               ChurchType
  denomination       String
  address            String
  city               String
  state              String?
  country            String
  countryCode        String
  postalCode         String?
  latitude           Float?
  longitude          Float?
  phone              String?
  email              String?
  website            String?
  dioceseId          String?
  isVerified         Boolean              @default(false)
  verifiedAt         DateTime?
  claimedBy          String?
  description        String?
  shortDescription   String?
  history            String?
  primaryImageUrl    String?
  virtualTourUrl     String?
  massSchedule       Json?
  confessionSchedule Json?
  adorationSchedule  Json?
  externalId         String?
  lastSyncedAt       DateTime?
  viewCount          Int                  @default(0)
  followerCount      Int                  @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  calendarUrl        String?
  stripeAccountId    String?
  totalDonations     Int                  @default(0)
  donationCount      Int                  @default(0)
  Diocese            Diocese?             @relation(fields: [dioceseId], references: [id])
  ChurchAdmin        ChurchAdmin[]
  ChurchAnnouncement ChurchAnnouncement[]
  ChurchClaim        ChurchClaim[]
  ChurchEvent        ChurchEvent[]
  ChurchFollower     ChurchFollower[]
  ChurchImage        ChurchImage[]
  ChurchStaff        ChurchStaff[]
  ChurchSubscription ChurchSubscription?
  PrayerRequest      PrayerRequest[]
  SacramentRecord    SacramentRecord[]
  User               User[]
  ConfessionLog      ConfessionLog[]
  Donation           Donation[]

  @@index([city, country])
  @@index([denomination])
  @@index([isVerified])
  @@index([latitude, longitude])
  @@index([name])
  @@index([slug])
}

model ChurchAdmin {
  id                   String          @id @default(cuid())
  churchId             String
  userId               String
  role                 ChurchAdminRole @default(EDITOR)
  canEditInfo          Boolean         @default(true)
  canPostAnnouncements Boolean         @default(true)
  canManageEvents      Boolean         @default(true)
  canManageAdmins      Boolean         @default(false)
  canViewAnalytics     Boolean         @default(true)
  invitedBy            String?
  invitedAt            DateTime        @default(now())
  acceptedAt           DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  Church               Church          @relation(fields: [churchId], references: [id], onDelete: Cascade)
  User                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([churchId, userId])
  @@index([churchId])
  @@index([userId])
}

model ChurchAnnouncement {
  id          String    @id @default(cuid())
  churchId    String
  title       String
  content     String
  imageUrl    String?
  linkUrl     String?
  linkText    String?
  isPinned    Boolean   @default(false)
  isPublished Boolean   @default(true)
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  pushSent    Boolean   @default(false)
  pushSentAt  DateTime?
  viewCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  Church      Church    @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId])
  @@index([isPublished, publishedAt])
}

model ChurchClaim {
  id                 String      @id @default(cuid())
  claimCode          String      @unique @default(cuid())
  churchId           String
  userId             String
  claimantName       String
  claimantTitle      String
  claimantEmail      String
  claimantPhone      String
  status             ClaimStatus @default(PENDING)
  emailVerified      Boolean     @default(false)
  emailVerifiedAt    DateTime?
  smsVerified        Boolean     @default(false)
  smsVerifiedAt      DateTime?
  emailOtp           String?
  emailOtpExpires    DateTime?
  smsOtp             String?
  smsOtpExpires      DateTime?
  documentsSubmitted Boolean     @default(false)
  documentsNotes     String?
  reviewedBy         String?
  reviewedAt         DateTime?
  reviewNotes        String?
  rejectionReason    String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  Church             Church      @relation(fields: [churchId], references: [id])
  User               User        @relation(fields: [userId], references: [id])

  @@index([churchId])
  @@index([status])
  @@index([userId])
}

model ChurchEvent {
  id              String    @id @default(cuid())
  churchId        String
  title           String
  description     String?
  eventType       EventType
  startDate       DateTime
  endDate         DateTime?
  isAllDay        Boolean   @default(false)
  isRecurring     Boolean   @default(false)
  recurrence      Json?
  location        String?
  imageUrl        String?
  registrationUrl String?
  maxAttendees    Int?
  isPublished     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  Church          Church    @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId])
  @@index([startDate])
}

model ChurchFollower {
  id            String   @id @default(cuid())
  churchId      String
  userId        String
  pushEnabled   Boolean  @default(true)
  emailEnabled  Boolean  @default(false)
  isParishioner Boolean  @default(false)
  followedAt    DateTime @default(now())
  Church        Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  User          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([churchId, userId])
  @@index([churchId])
  @@index([userId])
}

model ChurchImage {
  id        String   @id @default(cuid())
  churchId  String
  url       String
  caption   String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  Church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId])
}

model ChurchStaff {
  id        String   @id @default(cuid())
  churchId  String
  name      String
  title     String
  email     String?
  phone     String?
  imageUrl  String?
  bio       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId])
}

model ChurchSubscription {
  id                 String     @id @default(cuid())
  churchId           String     @unique
  tier               ChurchTier @default(UNCLAIMED)
  paidAmount         Float?
  paidAt             DateTime?
  stripePaymentId    String?
  announcementsLimit Int?
  eventsLimit        Int?
  adminsLimit        Int        @default(1)
  isActive           Boolean    @default(false)
  activatedAt        DateTime?
  expiresAt          DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  Church             Church     @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([tier])
}

model DailyQuote {
  id        String   @id
  date      DateTime @unique
  content   String
  author    String?
  source    String?
  category  String?
  reference String?
  imageUrl  String?
  createdAt DateTime @default(now())

  @@index([category])
  @@index([date])
}

model DailyReading {
  id               String   @id
  date             DateTime @unique
  liturgicalSeason String?
  liturgicalColor  String?
  feastName        String?
  firstReading     String?
  firstReadingRef  String?
  psalm            String?
  psalmRef         String?
  secondReading    String?
  secondReadingRef String?
  gospel           String?
  gospelRef        String?
  reflection       String?
  createdAt        DateTime @default(now())

  @@index([date])
}

model DevotionalPoint {
  id        String   @id
  number    Int
  content   String
  book      String
  chapter   String?
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@unique([book, number])
  @@index([book, number])
}

model Diocese {
  id            String      @id
  name          String
  type          DioceseType
  country       String
  countryCode   String
  region        String
  bishopName    String?
  bishopTitle   String?
  address       String?
  phone         String?
  email         String?
  website       String?
  catholicCount Int?
  parishCount   Int?
  priestCount   Int?
  externalId    String?     @unique
  lastSyncedAt  DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  Church        Church[]

  @@index([country])
  @@index([region])
}

model GIRMItem {
  id        String   @id
  number    Int      @unique
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([number])
}

model Ministry {
  id               String       @id
  name             String
  slug             String       @unique
  type             MinistryType @default(OTHER)
  address          String?
  city             String?
  state            String?
  country          String?
  countryCode      String?
  postalCode       String?
  latitude         Float?
  longitude        Float?
  phone            String?
  email            String?
  website          String?
  description      String?
  missionStatement String?
  imageUrl         String?
  isVerified       Boolean      @default(false)
  externalId       String?      @unique
  lastSyncedAt     DateTime?
  dataSource       String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime

  @@index([state, city])
  @@index([type])
}

model NewsArticle {
  id          String   @id @default(cuid())
  externalId  String   @unique
  source      String
  title       String
  summary     String?
  content     String?
  imageUrl    String?
  linkUrl     String
  author      String?
  category    String?
  publishedAt DateTime
  fetchedAt   DateTime @default(now())

  @@index([category])
  @@index([publishedAt], map: "news_published_at_idx")
  @@index([source])
}

model Article {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  content       String        @db.Text
  excerpt       String?       @db.Text
  category      String
  status        ArticleStatus @default(DRAFT)
  authorId      String
  author        User          @relation(fields: [authorId], references: [id])
  featuredImage String?
  views         Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  @@index([slug])
  @@index([category])
  @@index([status])
  @@index([authorId])
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model UserNotification {
  id        String           @id
  userId    String
  type      UserNotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  User      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isRead])
  @@index([userId])
}

model NewsletterSubscriber {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  isActive      Boolean  @default(true)
  subscribedAt  DateTime @default(now())
  unsubscribedAt DateTime?
  source        String?  @default("footer")
  
  @@index([email])
  @@index([isActive])
  @@index([subscribedAt])
}

model PrayerAction {
  id              String        @id @default(cuid())
  prayerRequestId String
  userId          String
  prayedAt        DateTime      @default(now())
  PrayerRequest   PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  User            User          @relation(fields: [userId], references: [id])

  @@unique([prayerRequestId, userId])
  @@index([prayerRequestId])
  @@index([userId])
}

model PrayerLibraryCategory {
  id                          String                  @id
  name                        String
  slug                        String                  @unique
  description                 String?
  iconName                    String?
  color                       String?
  parentId                    String?
  sortOrder                   Int                     @default(0)
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime
  PrayerLibraryCategory       PrayerLibraryCategory?  @relation("PrayerLibraryCategoryToPrayerLibraryCategory", fields: [parentId], references: [id])
  children                    PrayerLibraryCategory[] @relation("PrayerLibraryCategoryToPrayerLibraryCategory")

  @@index([parentId])
}

model PrayerRequest {
  id              String           @id @default(cuid())
  userId          String
  title           String?
  content         String
  category        PrayerCategory
  visibility      PrayerVisibility @default(PUBLIC)
  isAnonymous     Boolean          @default(false)
  churchId        String?
  status          ModerationStatus @default(PENDING)
  moderatedBy     String?
  moderatedAt     DateTime?
  moderationNotes String?
  rejectionReason String?
  prayerCount     Int              @default(0)
  isAnswered      Boolean          @default(false)
  answeredAt      DateTime?
  testimony       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  prayerActions    PrayerAction[]
  church           Church?          @relation(fields: [churchId], references: [id])
  user             User             @relation(fields: [userId], references: [id])
  prayerUpdates    PrayerUpdate[]
  prayerComments   PrayerComment[]
  prayerFollowing  PrayerFollowing[]

  @@index([category])
  @@index([isAnswered])
  @@index([status])
  @@index([userId])
  @@index([visibility])
  @@index([createdAt])
  @@index([churchId])
}

model PrayerUpdate {
  id              String        @id
  prayerRequestId String
  content         String
  createdAt       DateTime      @default(now())
  PrayerRequest   PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)

  @@index([prayerRequestId])
}

model SacramentRecord {
  id             String          @id
  churchId       String
  userId         String?
  type           SacramentType
  candidateName  String
  date           DateTime
  minister       String?
  status         SacramentStatus @default(SCHEDULED)
  certificateUrl String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime
  Church         Church          @relation(fields: [churchId], references: [id])
  User           User?           @relation(fields: [userId], references: [id])

  @@index([churchId])
  @@index([status])
  @@index([type])
  @@index([userId])
}

model Saint {
  id              String    @id
  name            String
  slug            String    @unique
  title           String?
  feastDay        String?
  feastMonth      Int?
  feastDayOfMonth Int?
  biography       String?
  shortBio        String?
  imageUrl        String?
  patronOf        String[]
  bornDate        String?
  diedDate        String?
  canonizedDate   String?
  externalId      String?
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime

  @@index([feastMonth, feastDayOfMonth])
  @@index([name])
  @@index([slug])
}

model Session {
  id         String   @id
  userId     String
  token      String   @unique
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model SponsoredContent {
  id              String    @id
  type            AdType
  title           String
  description     String?
  imageUrl        String?
  linkUrl         String?
  placement       String
  advertiser      String
  advertiserEmail String?
  startDate       DateTime
  endDate         DateTime
  impressions     Int       @default(0)
  clicks          Int       @default(0)
  paidAmount      Float?
  stripePaymentId String?
  isActive        Boolean   @default(false)
  isApproved      Boolean   @default(false)
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime

  // Ad source configuration (Google AdMob/AdSense vs Offline Sponsor)
  adSource        AdSource  @default(OFFLINE)
  googleAdUnitId  String?   // Google AdSense unit ID (web fallback)
  priority        Int       @default(0) // Higher priority shown first
  targetPages     String[]  // Multiple pages targeting
  
  // Multi-platform support
  platforms       String[]  @default(["web"]) // ["web", "android", "ios", "all"]
  androidAdUnitId String?   // AdMob unit ID for Android
  iosAdUnitId     String?   // AdMob unit ID for iOS

  @@index([placement, isActive])
  @@index([startDate, endDate])
  @@index([adSource, isActive])
}

model SyncLog {
  id               String     @id @default(cuid())
  source           String
  type             String
  status           SyncStatus
  startedAt        DateTime   @default(now())
  completedAt      DateTime?
  recordsProcessed Int        @default(0)
  recordsCreated   Int        @default(0)
  recordsUpdated   Int        @default(0)
  recordsFailed    Int        @default(0)
  errorMessage     String?
  errorDetails     Json?
  triggeredBy      String?

  @@index([source])
  @@index([startedAt])
  @@index([status])
}

model User {
  id                                         String            @id
  email                                      String            @unique
  emailVerified                              Boolean           @default(false)
  phone                                      String?
  phoneVerified                              Boolean           @default(false)
  passwordHash                               String?
  firstName                                  String?
  lastName                                   String?
  displayName                                String?
  avatarUrl                                  String?
  bio                                        String?
  language                                   String            @default("en")
  timezone                                   String            @default("UTC")
  notificationsEnabled                       Boolean           @default(true)
  subscriptionTier                           SubscriptionTier  @default(FREE)
  subscriptionEnds                           DateTime?
  subscriptionSource                         PaymentSource?
  stripeCustomerId                           String?
  
  // Google Play Billing
  googlePlayPurchaseToken                    String?
  subscriptionStatus                         String?
  subscriptionId                             String?
  googlePlaySubscriptionId                   String?
  googlePlayOrderId                          String?
  homeChurchId                               String?
  createdAt                                  DateTime          @default(now())
  updatedAt                                  DateTime
  lastLoginAt                                DateTime?
  lastConfessionAt                           DateTime?
  lastStreakUpdate                           DateTime?
  longestStreak                              Int               @default(0)
  streakCount                                Int               @default(0)
  currentStreak                              Int               @default(0)
  totalPrayers                               Int               @default(0)
  totalPrayedFor                             Int               @default(0)
  level                                      Int               @default(1)
  xp                                         Int               @default(0)

  @@unique([userChallengeId, day])
  @@index([userChallengeId])
}

model UserAchievement {
  id            String          @id @default(cuid())
  userId        String
  achievementId String
  tier          AchievementTier @default(BRONZE)
  progress      Int             @default(0)
  maxProgress   Int             @default(100)

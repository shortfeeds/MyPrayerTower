# Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/myprayertower?schema=public"
REDIS_URL="redis://localhost:6379"

# Authentication (Firebase)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# SMS (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Email (SendGrid)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@myprayertower.com"
VERIFICATION_EMAIL="verify@myprayertower.com"

# Payments (Stripe)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# App Settings
NODE_ENV="development"
API_URL="http://localhost:4000"
WEB_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3001"

# Scraper Settings
GCATHOLIC_SYNC_ENABLED="true"
GCATHOLIC_SYNC_CRON="0 2 * * 0"  # Every Sunday at 2 AM UTC

# Security
JWT_SECRET=""
ENCRYPTION_KEY=""

# Push Notifications (Firebase)
FCM_SERVER_KEY=""

# ===========================================
# AD MONETIZATION (Google AdMob / AdSense)
# ===========================================

# Website - Google AdSense Client ID (format: ca-pub-XXXXXXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=""

# Mobile App - Google AdMob App IDs
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=""
EXPO_PUBLIC_ADMOB_IOS_APP_ID=""

# Mobile App - AdMob Ad Unit IDs
EXPO_PUBLIC_ADMOB_HOME_BANNER=""
EXPO_PUBLIC_ADMOB_INLINE=""
EXPO_PUBLIC_ADMOB_CONTENT=""

# ===========================================
# YOUTUBE DATA API
# ===========================================
YOUTUBE_API_KEY=""

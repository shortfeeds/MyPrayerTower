# Database Configuration for MyPrayerTower

# For Supabase, use the pooler connection (port 6543) for the main URL
# and direct connection (port 5432) for migrations

# Main connection URL - Uses Connection Pooler (PgBouncer)
# This is used for all runtime queries
DATABASE_URL="postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection URL - Uses Direct PostgreSQL connection
# This is used for migrations and schema changes
DIRECT_URL="postgres://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres"

# Replace:
# - [project-ref] with your Supabase project reference
# - [password] with your database password
# - [region] with your Supabase region (e.g., us-east-1)

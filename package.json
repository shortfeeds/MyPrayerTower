{
  "name": "myprayertower",
  "version": "1.0.0",
  "private": true,
  "description": "MyPrayerTower - All-in-One Catholic Services Platform",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @mpt/database db:generate",
    "db:migrate": "pnpm --filter @mpt/database db:migrate",
    "db:push": "pnpm --filter @mpt/database db:push",
    "db:studio": "pnpm --filter @mpt/database db:studio",
    "import:netministries": "npm run import:netministries --workspace=@mpt/scraper",
    "hostinger-deploy": "npx pnpm install --no-frozen-lockfile --shamefully-hoist && chmod -R +x node_modules/.pnpm/@prisma+engines* node_modules/@prisma/engines || true && npx pnpm prisma generate --schema=packages/database/prisma/schema.prisma && npx pnpm --filter @mpt/web build && node scripts/deploy-copy.js"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}